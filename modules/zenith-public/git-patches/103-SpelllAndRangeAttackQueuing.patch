+        if (
+            POwner->objtype == TYPE_PC &&
+            POwner->PAI->IsCurrentState<CMagicState>()
+        )
+        {
+            // ShowDebug("Got spellcast request while already spellcasting...\n");
+            if (POwner->PAI->GetCurrentState()->IsCompleted())
