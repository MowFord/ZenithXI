diff --git a/src/map/ai/ai_container.cpp b/src/map/ai/ai_container.cpp
index 4d3ec21190..3635cfd6b4 100644
--- a/src/map/ai/ai_container.cpp
+++ b/src/map/ai/ai_container.cpp
@@ -450,6 +453,32 @@ void CAIContainer::Tick(time_point _tick)
             state->Cleanup(_tick);
         }
     }
+    auto* PChar = dynamic_cast<CCharEntity*>(PEntity);
+    if (
+        (m_queuedRangedAttack || m_queuedSpellTargId) &&
+        PChar &&
+        PChar->PAI &&
+        PChar->PAI->CanChangeState()
+    )
+    {
+        // ShowDebug("Checking player queue...\n");
+        if (
+            m_queuedRangedAttack &&
+            _tick - PChar->m_LastRangedAttackTime > std::chrono::milliseconds(1100) // phase 3 waittime for ranged attacks
+        )
+        {
+            // ShowDebug("Doing queued ranged attack...\n");
+            RangedAttack(m_queuedRangedAttack);
+            m_queuedRangedAttack = 0;
+        }
+        else if (m_queuedSpellTargId)
+        {
+            // ShowDebug("Doing queued spell...\n");
+            Cast(m_queuedSpellTargId, m_queuedSpell);
+            m_queuedSpell = (SpellID)0;
+            m_queuedSpellTargId = 0;
+        }
+    }
 
     PEntity->PostTick();
 }
